# Python caches
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Run artifacts — contain LIVE ACCOUNT DATA (positions, $ amounts) + reports. Never commit.
runs/
reports/

# Browser-automation (playwright-mcp) scratch logs
.playwright-mcp/

# Skill-owned venv (bootstrap: scripts/setup_venv.sh)
.venv/

# Rolling resume-pointer handoff (internal working note — never publish in this public repo)
handoff-*.md

# Local usage telemetry sink (0600, uncommitted — privacy publication boundary)
.local-usage/

# Catch-all for option tokens accidentally bound as an output path. A `--help`
# probe once became snapshot_holdings.py's output dir and wrote LIVE holdings to
# ./--help/ here. The scripts now guard their argv; this is the second line of
# defense so such a path can never be committed (R4).
/--*/
/--*

# Agent-harness scaffolding that lands in the project root. Not project code:
# session-env/ is a Stop-gate verification marker written per Claude Code
# session (a second session dropped one here); .serena/ is Serena MCP's project
# cache. Neither belongs in a public repo.
session-env/
.serena/
